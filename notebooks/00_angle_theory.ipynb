# The core claim of this lab:
# A claim is consistent (VC) iff its representation is within 10° of its constraint basis.
# At 45°, the claim is maximally unstable — it will collapse into IA/ZOS.

import matplotlib.pyplot as plt
import numpy as np

angles = np.linspace(0, 90, 100)
stability = np.cos(np.radians(angles))  # Cosine constraint

plt.figure(figsize=(10, 4))
plt.plot(angles, stability, 'k-', linewidth=2)
plt.axvline(45, color='red', linestyle='--', label='45° critical boundary')
plt.axvline(10, color='green', linestyle=':', label='VC lock zone')
plt.fill_between(angles, 0, stability, where=(angles>35)&(angles<55), color='red', alpha=0.2)
plt.title("Cosine Constraint: Stability vs Angle")
plt.xlabel("Angle between claim and constraint basis (degrees)")
plt.ylabel("cos(θ) — alignment")
plt.legend()
plt.show()
